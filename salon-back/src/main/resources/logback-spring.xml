<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <conversionRule conversionWord="mask" class="com.cristiane.salon.config.logging.MaskingMessageConverter" />
    <appender name="CUSTOM_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>[%d{yyyy-MM-dd HH:mm:ss.SSS, America/Recife}] | %-5level | ${PID:- } | [%15.15t] | %-40.40logger{39} | %mask%n</pattern>
        </encoder>
    </appender>
</configuration>
