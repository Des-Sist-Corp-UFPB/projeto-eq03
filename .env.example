# ============================================================
# SALON — Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# Para ambiente Docker local, os valores abaixo já funcionam.
# ============================================================

# --- Banco de Dados ---
# Docker local: usa o hostname interno do serviço "db" do Docker Compose
# Fora do Docker (mvn spring-boot:run): use jdbc:postgresql://localhost:5432/salon_dev
DB_URL=jdbc:postgresql://db:5432/salon_dev
DB_USER=salon
DB_PASS=salon

# --- Segurança JWT (OBRIGATÓRIO trocar em produção) ---
JWT_SECRET=dev-secret-key-change-in-prod-must-be-at-least-256-bits-long!!

# --- E-mail / SMTP ---
# Docker local: aponta para o Mailpit (hostname interno "mailpit", porta SMTP 1025)
# Produção: troque pelos dados do seu servidor SMTP real (ex: SendGrid, AWS SES)
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false

# --- Frontend (Vite build-time) ---
# Docker (Nginx proxy reverso): use /v1
# Desenvolvimento local sem Docker (npm run dev): use http://localhost:8080/v1
VITE_API_URL=/v1
