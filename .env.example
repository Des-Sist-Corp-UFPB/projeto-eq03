# ──────────────────────────────────────────────────────────────────────────────
# Banco de Dados (PostgreSQL)
# Localmente: docker compose up -d db  →  porta exposta em 5433
# ──────────────────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5433/salon_dev
DB_USER=salon
DB_PASS=salon
DB_PASSWORD=salon

# ──────────────────────────────────────────────────────────────────────────────
# Autenticação JWT
# Gere um valor seguro para produção: openssl rand -hex 64
# ──────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-must-be-at-least-256-bits-long-use-openssl-rand

# ──────────────────────────────────────────────────────────────────────────────
# E-mail (Resend)
# https://resend.com/api-keys
# ──────────────────────────────────────────────────────────────────────────────
MAIL_API_URL=https://api.resend.com/
MAIL_PASSWORD=re_your_api_key_here
MAIL_FROM=noreply@yourdomain.com
MAIL_BUSINESS=your_business_email@example.com

# ──────────────────────────────────────────────────────────────────────────────
# Pagamentos (Mercado Pago)
# Tokens de teste começam com TEST-  |  Produção: APP_USR-
# https://www.mercadopago.com.br/developers/panel/app
# ──────────────────────────────────────────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=TEST-your-mp-access-token-here
MERCADO_PAGO_WEBHOOK_SECRET=your-mp-webhook-secret-here

# ──────────────────────────────────────────────────────────────────────────────
# Central de IA (recomendações + servidor MCP)
# Chave AES-256 em base64 que cifra a API key de IA salva pelo Sysadmin em tb_ai_config.
# Gere com: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# A API key do provedor (LiteLLM) em si NÃO vai aqui — é configurada pela tela de Sysadmin.
# ──────────────────────────────────────────────────────────────────────────────
AI_CONFIG_ENCRYPTION_KEY=change-me-generate-a-real-base64-32-byte-key-for-production

# ──────────────────────────────────────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────────────────────────────────────
VITE_API_URL=/v1

# ──────────────────────────────────────────────────────────────────────────────
# CORS (produção — deixe vazio para usar o padrão do application.yaml)
# ──────────────────────────────────────────────────────────────────────────────
APP_CORS_ALLOWED_ORIGINS=

# ──────────────────────────────────────────────────────────────────────────────
# Testes de Carga (k6)
# BASE_URL aponta para onde o backend está rodando durante o teste
# ──────────────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost
ADMIN_EMAIL=sysadmin@salao.com
ADMIN_PASSWORD=your-sysadmin-password-here